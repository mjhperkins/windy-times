---
import Base from "../layouts/Base.astro";
---

<Base title="About - The Windy Times">
  <article class="max-w-2xl mx-auto">
    <h1 class="headline-lg mb-6">About The Windy Times</h1>

    <div class="rule mb-6"></div>

    <section class="mb-8">
      <h2 class="headline-md mb-4">About the Editor</h2>
      <div class="flex gap-6 items-start">
        <img
          src="/michael-perkins.jpg"
          alt="Michael Perkins"
          class="w-40 h-40 rounded-lg object-cover flex-shrink-0"
        />
        <div>
          <p class="summary">
            I'm a Melbourne-based wind energy professional currently working at Vestas. After 15 years in the Australian renewable energy industry, I created The Windy Times to help others stay informed about the sector's rapid evolution.
          </p>
          <p class="summary mt-4">
            — <a href="https://au.linkedin.com/in/michael-perkins-11b2a710b" target="_blank" rel="noopener noreferrer" class="link-blue">Michael Perkins</a>
          </p>
        </div>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="headline-md mb-4">Our Sources</h2>
      <p class="summary">
        We aggregate news from energy publications such as RenewEconomy, WattClarity, the AFR and PV Magazine Australia as well as industry sources such as the Clean Energy Council, EnergyCo and QREC.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="headline-md mb-4">How Content is Selected</h2>
      <p class="summary">
        Articles are curated using AI-assisted filtering to identify stories
        relevant to the Australian wind energy sector. Each article is reviewed
        for relevance before being published to this site.
      </p>
      <p class="summary mt-4">
        The underlying news aggregator monitors RSS feeds from our sources and
        uses machine learning to identify articles about wind energy, renewable
        energy policy, grid infrastructure, and related topics.
      </p>
    </section>

    <section>
      <h2 class="headline-md mb-4">Contact</h2>
      <p class="summary">
        <!-- TODO: Add contact information -->
        For questions or feedback, please contact [your email or contact method].
      </p>
    </section>
  </article>
</Base>
