---
import Base from "../layouts/Base.astro";
---

<Base title="About - The Windy Times">
  <article class="max-w-2xl mx-auto">
    <h1 class="headline-lg mb-6">About The Windy Times</h1>

    <div class="rule mb-6"></div>

    <section class="mb-8">
      <h2 class="headline-md mb-4">About the Editor</h2>
      <p class="summary">
        The Windy Times is curated by <a href="https://au.linkedin.com/in/michael-perkins-11b2a710b" target="_blank" rel="noopener noreferrer" class="link-blue">Michael Perkins</a>, a Melbourne-based wind energy professional currently working at Vestas. After 15 years in the Australian renewable energy industry, Michael created The Windy Times to help others stay informed about the sector's rapid evolution.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="headline-md mb-4">Our Sources</h2>
      <p class="summary mb-4">
        We aggregate news from trusted Australian energy publications:
      </p>
      <ul class="list-disc list-inside summary space-y-2">
        <!-- TODO: Update this list with your actual sources -->
        <li>RenewEconomy</li>
        <li>PV Magazine Australia</li>
        <li>Australian Energy Council</li>
        <li>Clean Energy Council</li>
        <!-- Add more sources as needed -->
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="headline-md mb-4">How Content is Selected</h2>
      <p class="summary">
        Articles are curated using AI-assisted filtering to identify stories
        relevant to the Australian wind energy sector. Each article is reviewed
        for relevance before being published to this site.
      </p>
      <p class="summary mt-4">
        The underlying news aggregator monitors RSS feeds from our sources and
        uses machine learning to identify articles about wind energy, renewable
        energy policy, grid infrastructure, and related topics.
      </p>
    </section>

    <section>
      <h2 class="headline-md mb-4">Contact</h2>
      <p class="summary">
        <!-- TODO: Add contact information -->
        For questions or feedback, please contact [your email or contact method].
      </p>
    </section>
  </article>
</Base>
