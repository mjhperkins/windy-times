---
import Base from "../layouts/Base.astro";
import { fetchArticlesWithImages, formatDateShort, truncateSummary } from "../lib/feed";

const articles = await fetchArticlesWithImages(20);
---

<Base>
  {articles.length === 0 ? (
    <p class="text-center py-12 text-[var(--color-text-muted)]">
      No articles available at this time.
    </p>
  ) : (
    <div>
      <!-- Articles Grid - Uniform 2-column layout -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {articles.map((article, index) => (
          <article class:list={[
            "pb-6",
            index < articles.length - 1 && "border-b border-[var(--color-rule)] md:border-b-0"
          ]}>
            {article.image && (
              <a href={article.link} target="_blank" rel="noopener noreferrer">
                <img
                  src={article.image}
                  alt=""
                  class="w-full h-48 object-cover mb-4"
                />
              </a>
            )}
            <a href={article.link} target="_blank" rel="noopener noreferrer">
              <h2 class="headline-md hover:text-[var(--color-link)]">
                {article.title}
              </h2>
            </a>
            <p class="summary mt-2">{truncateSummary(article.summary)}</p>
            <p class="byline mt-2">
              {article.source} · {formatDateShort(article.pubDate)}
            </p>
          </article>
        ))}
      </section>

      <!-- View All Link -->
      <div class="text-center py-8">
        <a
          href="/archive"
          class="inline-block px-6 py-3 border border-[var(--color-rule-dark)] text-sm font-sans hover:bg-[var(--color-text)] hover:text-white transition-colors"
        >
          View All Stories →
        </a>
      </div>
    </div>
  )}
</Base>
